{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowAppRunnerRoleToReadWriteInvoices",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::YOUR_ACCOUNT_ID:role/YOUR_APP_RUNNER_INSTANCE_ROLE_NAME"
      },
      "Action": [
        "s3:PutObject",
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/invoices/*"
    }
  ]
}
